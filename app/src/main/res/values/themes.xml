<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовая тема приложения -->
    <style name="Theme.CrossfitArmyJym" parent="Theme.Material3.Light.NoActionBar">
        <!-- Основные цвета -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Цвета поверхности -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Текст -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Статус бар -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/army_navy</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/army_red</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
    </style>

    <!-- Тема для экрана аутентификации (без статус бара) -->
    <style name="Theme.CrossfitArmyJym.Auth" parent="Theme.CrossfitArmyJym">
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Тема для диалогов -->
    <style name="Theme.CrossfitArmyJym.Dialog" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Тема для всплывающих меню -->
    <style name="Theme.CrossfitArmyJym.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <!-- Стили для TextInputLayout -->
    <style name="Widget.CrossfitArmyJym.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- Стили для кнопок -->
    <style name="Widget.CrossfitArmyJym.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CrossfitArmyJym.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- Стили для карточек -->
    <style name="Widget.CrossfitArmyJym.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">14dp</item>
    </style>

    <style name="TextAppearance.CrossfitArmyJym.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/army_navy</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="TextAppearance.CrossfitArmyJym.Action" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/army_navy</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
