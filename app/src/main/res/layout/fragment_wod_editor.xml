<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="156dp"
            android:background="@drawable/bg_army_screen_header"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">
            <TextView
                style="@style/Widget.CrossfitArmyJym.ScreenTitle.OnDark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/trainer_wod_title" />
            <View
                android:layout_width="72dp"
                android:layout_height="4dp"
                android:layout_marginTop="7dp"
                android:background="@color/army_red" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:text="@string/trainer_wod_subtitle"
                android:textColor="#B8C7CE"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CrossfitArmyJym.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-condensed"
                    android:text="@string/wod_main_section"
                    android:textColor="@color/army_navy"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_wod_name"
                    style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/wod_name_hint">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_wod_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/wod_format_label"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_format"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/wod_group_label"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_group"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/wod_date_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_scheduled_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="@string/wod_time_cap_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_time_cap"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.CrossfitArmyJym.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-condensed"
                    android:text="@string/wod_tasks_section"
                    android:textColor="@color/army_navy"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_task_title"
                    style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/wod_task_title_hint">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_task_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/wod_rx_exercise_label"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_rx_exercise"
                    android:layout_width="match_parent"
                    android:layout_height="52dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/wod_load_type_label"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_load_type"
                    android:layout_width="match_parent"
                    android:layout_height="52dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_rx_load"
                    style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/wod_rx_load_hint">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_rx_load"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine"
                        android:lines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/wod_optional_exercise_label"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_optional_exercise"
                    android:layout_width="match_parent"
                    android:layout_height="52dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_optional_load"
                        style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/wod_optional_load_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_optional_load"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_task_notes"
                        style="@style/Widget.CrossfitArmyJym.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="@string/wod_task_notes_hint">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_task_notes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_task"
                    style="@style/Widget.CrossfitArmyJym.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/wod_add_task"
                    app:cornerRadius="8dp" />
                <TextView
                    android:id="@+id/tv_selected_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_diagonal_pattern"
                    android:padding="12dp"
                    android:text="@string/wod_no_tasks"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_wod_description"
            style="@style/Widget.CrossfitArmyJym.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:hint="@string/wod_description_hint">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_wod_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:lines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_wod"
            style="@style/Widget.CrossfitArmyJym.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:text="@string/save"
            app:cornerRadius="8dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:indeterminateTint="@color/army_red"
            android:visibility="gone" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
