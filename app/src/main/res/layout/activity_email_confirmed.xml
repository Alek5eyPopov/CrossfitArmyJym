<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/army_navy"
    tools:context=".ui.auth.EmailConfirmedActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_auth_city_label"
                android:fontFamily="sans-serif-condensed"
                android:text="@string/army_city"
                android:textColor="@color/text_on_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.08"
                android:text="@string/army_club"
                android:textColor="@color/text_on_primary"
                android:textSize="38sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_auth_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="48dp"
            android:paddingEnd="28dp"
            android:paddingBottom="32dp">

            <FrameLayout
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:background="@drawable/bg_email_confirmation_icon"
                android:padding="25dp">

                <ImageView
                    android:id="@+id/iv_status"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/email_confirmed_title"
                    android:src="@drawable/army_emblem_white" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_title"
                style="@style/Widget.CrossfitArmyJym.ScreenTitle.OnLight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="@string/email_confirmed_title" />

            <View
                android:layout_width="72dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@color/army_red" />

            <TextView
                android:id="@+id/tv_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/email_confirmed_message"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login"
                style="@style/Widget.CrossfitArmyJym.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="36dp"
                android:text="@string/email_confirmed_login"
                android:textSize="15sp"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.05"
                android:text="@string/auth_footer"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
